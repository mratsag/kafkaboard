KAFKABOARD_BACKEND_IMAGE=kafkaboard-backend:latest
KAFKABOARD_UI_IMAGE=kafkaboard-ui:latest

POSTGRES_DB=kafkaboard
POSTGRES_USER=kafkaboard
POSTGRES_PASSWORD=change-this-postgres-password

JWT_SECRET=change-this-to-a-strong-secret-min-32-chars
ENCRYPTION_KEY=change-this-32-char-encryption-key

# User-configurable published ports
FRONTEND_PORT=8090
BACKEND_PORT=8080

# Optional. Keep the default unless you know the trusted proxy IPs in front of the backend.
TRUSTED_PROXIES=127.0.0.1,::1
